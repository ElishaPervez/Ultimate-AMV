# Donor projects kept for reference only.
reference/

# moongetsu's PRIVATE Tsukyio AE extension source. Shared in confidence to
# document the vault API — reference only. MUST NOT be committed to the public repo.
Tsukyio-AE-Extension-development/

# Local agent/editor state. docs/agent/ holds the workflow rules split
# out of CLAUDE.md — same privacy as CLAUDE.md itself, keep local-only.
.claude/
.vscode/
.idea/
.codex
.antigravitycli/
CLAUDE.md
AGENTS.md
